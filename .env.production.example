# Sunucuda bu dosyayi ".env" olarak kaydet (docker-compose.yml ile ayni dizinde)
# cp .env.production.example .env
# Gercek degerleri asla git'e commit etme -- .env zaten .gitignore'da.

# --- docker-compose degiskenleri ---
DOMAIN=demirwingtsun.com
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Backend (app/config.py Settings) ---
ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://wteo:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/wteo

# Uretmek icin: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_32_PLUS_CHAR_KEY

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=https://demirwingtsun.com,https://www.demirwingtsun.com

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@yourschool.com
MAIL_FROM_NAME=Wing Tsun & Escrima
