# Wing Tsun & Escrima - Environment Variables Example
# Bu dosyayı kopyalayıp .env olarak kaydedin: cp .env.example .env

# Database
DATABASE_URL=sqlite+aiosqlite:///./wteo.db
# PostgreSQL için: postgresql+asyncpg://user:password@localhost/dbname

# JWT - Üretimde mutlaka güçlü, rastgele bir key kullanın
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Token süreleri
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Frontend URL'leri (virgülle ayırın)
CORS_ORIGINS=http://localhost:5173

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Mail (SMTP) - Gerçek mail göndermek için
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@yourschool.com
MAIL_FROM_NAME=Wing Tsun & Escrima
